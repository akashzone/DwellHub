<%- layout("/layouts/boilerplate") %>

<body>
  <div class="container mt-3">
    <h1 class="mb-3">Listings</h1>
    <div class="row g-3">
      <% for (let l of sampleListing) { %>

        <div class="col-lg-4 col-md-6 col-sm-12">

          <div class="card listing-card h-100 border-0 shadow-sm">

            <a href="/listings/<%= l._id %>" class="listing-link">
              <img src="<%= l.image %>" class="card-img-top listing-img" alt="listing_image">
            </a>

            <div class="card-body">
              <p class="card-text mb-1 fw-semibold">
                <%= l.title %>
              </p>
              <p class="text-muted mb-0">
                ₹ <%= l.price.toLocaleString("en-IN") %> / night
              </p>
            </div>

          </div>

        </div>

      <% } %>
    </div>

  </div>
</body>